rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isAuth() { return request.auth != null; }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 200 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('theme' in data) || (data.theme in ['light', 'dark', 'system'])) &&
             (!('language' in data) || (data.language is string && data.language.size() <= 10));
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             data.createdAt is number && data.updatedAt is number;
    }

    function isValidProjectMember(data) {
      return data.keys().hasAll(['userId', 'role', 'joinedAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.role in ['owner', 'editor', 'viewer'] &&
             data.joinedAt is number;
    }

    function isValidTask(data, projectId) {
      return data.keys().hasAll(['projectId', 'title', 'status', 'creatorId', 'createdAt', 'updatedAt']) &&
             data.projectId == projectId &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['todo', 'in_progress', 'done'] &&
             data.creatorId is string && data.creatorId == request.auth.uid &&
             data.createdAt is number && data.updatedAt is number &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('assigneeId' in data) || (data.assigneeId is string && data.assigneeId.size() <= 128)) &&
             (!('dueDate' in data) || (data.dueDate is number));
    }

    function isProjectMember(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }
    
    function getMemberRole(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
    }

    function isProjectOwnerOrEditor(projectId) {
      let role = getMemberRole(projectId);
      return role == 'owner' || role == 'editor';
    }

    // --- Collections ---
    match /users/{userId} {
      allow get: if isAuth() && isValidId(userId);
      allow list: if isAuth(); 
      allow create: if isAuth() && request.auth.uid == userId && isValidUser(incoming()) && incoming().keys().size() <= 5;
      allow update: if isAuth() && request.auth.uid == userId && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'theme', 'language']);
    }

    match /projects/{projectId} {
      allow get: if isAuth() && isValidId(projectId) && isProjectMember(projectId);
      allow list: if false; 

      allow create: if isAuth() && isValidId(projectId) && isValidProject(incoming()) && incoming().keys().size() <= 5;
      allow update: if isAuth() && isValidId(projectId) && isValidProject(incoming()) &&
                    isProjectOwnerOrEditor(projectId) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'updatedAt']);
      allow delete: if isAuth() && isValidId(projectId) && getMemberRole(projectId) == 'owner';

      match /members/{memberId} {
        allow get: if isAuth() && isValidId(projectId) && isValidId(memberId) && isProjectMember(projectId);
        allow list: if isAuth() && isValidId(projectId) && (resource.data.userId == request.auth.uid || isProjectMember(projectId));
        allow read: if isAuth() && resource.data.userId == request.auth.uid;

        allow create: if isAuth() && isValidId(projectId) && isValidId(memberId) && memberId == incoming().userId &&
                      isValidProjectMember(incoming()) && incoming().keys().size() == 3 &&
                      (isProjectOwnerOrEditor(projectId) || (incoming().role == 'owner' && incoming().userId == request.auth.uid));
        allow update: if isAuth() && isValidId(projectId) && isValidId(memberId) && isValidProjectMember(incoming()) &&
                      getMemberRole(projectId) == 'owner' &&
                      incoming().userId == existing().userId &&
                      incoming().joinedAt == existing().joinedAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['role']);
        allow delete: if isAuth() && isValidId(projectId) && isValidId(memberId) &&
                      (getMemberRole(projectId) == 'owner' || request.auth.uid == memberId);
      }

      match /tasks/{taskId} {
        allow get: if isAuth() && isValidId(projectId) && isValidId(taskId) && isProjectMember(projectId);
        allow list: if isAuth() && isValidId(projectId) && isProjectMember(projectId);
        allow read: if isAuth() && resource.data.assigneeId == request.auth.uid;

        allow create: if isAuth() && isValidId(projectId) && isValidId(taskId) && isValidTask(incoming(), projectId) &&
                      incoming().keys().size() >= 6 && incoming().keys().size() <= 9 &&
                      isProjectOwnerOrEditor(projectId);
        allow update: if isAuth() && isValidId(projectId) && isValidId(taskId) && isValidTask(incoming(), projectId) &&
                      isProjectMember(projectId) && 
                      (isProjectOwnerOrEditor(projectId) || existing().assigneeId == request.auth.uid || existing().creatorId == request.auth.uid) &&
                      incoming().projectId == existing().projectId &&
                      incoming().creatorId == existing().creatorId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'status', 'assigneeId', 'dueDate', 'updatedAt']);
        allow delete: if isAuth() && isValidId(projectId) && isValidId(taskId) &&
                      (isProjectOwnerOrEditor(projectId) || existing().creatorId == request.auth.uid);
      }
    }
  }
}