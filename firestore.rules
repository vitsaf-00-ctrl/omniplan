rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(userId) { return isAuth() && request.auth.uid == userId; }

    // ── Personal tasks (users/{userId}/tasks) ─────────────────────────────────
    // Each user can only read/write their own tasks.
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if isOwner(userId);
    }
    // ── Personal projects (users/{userId}/projects) ───────────────────────────
    match /users/{userId}/projects/{projectId} {
      allow read, write: if isOwner(userId);
    }

    // ── User profile & settings ───────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isAuth() && request.auth.uid == userId;
      allow create, update: if isOwner(userId);
    }

    // ── Invites (global collection) ───────────────────────────────────────────
    // Sender can create/delete their own invites.
    // Receiver can read invites addressed to their email and update the status.
    match /invites/{inviteId} {
      allow read: if isAuth() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toEmail == request.auth.token.email
      );
      allow create: if isAuth() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.toEmail is string &&
        request.resource.data.toEmail.size() > 3;
      allow update: if isAuth() &&
        resource.data.toEmail == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['accepted', 'rejected'];
      allow delete: if isAuth() && resource.data.fromUid == request.auth.uid;
    }

    // ── Legacy project-based collections (kept for backward compatibility) ─────
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isProjectMember(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
    }

    function getMemberRole(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid)).data.role;
    }

    function isProjectOwnerOrEditor(projectId) {
      let role = getMemberRole(projectId);
      return role == 'owner' || role == 'editor';
    }

    match /projects/{projectId} {
      allow get: if isAuth() && isValidId(projectId) && isProjectMember(projectId);
      allow list: if false;
      allow create: if isAuth() && isValidId(projectId);
      allow update: if isAuth() && isValidId(projectId) && isProjectOwnerOrEditor(projectId);
      allow delete: if isAuth() && isValidId(projectId) && getMemberRole(projectId) == 'owner';

      match /members/{memberId} {
        allow read: if isAuth() && isValidId(projectId) && isProjectMember(projectId);
        allow write: if isAuth() && isValidId(projectId) && isProjectOwnerOrEditor(projectId);
      }

      match /tasks/{taskId} {
        allow read: if isAuth() && isValidId(projectId) && isProjectMember(projectId);
        allow write: if isAuth() && isValidId(projectId) && isProjectOwnerOrEditor(projectId);
      }
    }
  }
}
